{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "checkJs": true,
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts", "uniwind-types.d.ts", "env.ts"],
  "exclude": [
    "node_modules",
    "babel.config.js",
    "metro.config.js",
    ".docs",
    "android",
    "ios",
    "lint-staged.config.js"
  ]
}
